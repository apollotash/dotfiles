[colors]
;background 	= #803F3F3F	;%50
background	= #E63F3F3F	
foreground 	= #add8e6
blue       	= #3fa9f4
green      	= #22b574
darkRed	   	= #d75f5f
white	   	= #ffffff
silverGray 	= #888888
lightBrown 	= #d2b48c
iceColor   	= #d3d3d3
lightGreen 	= #3cb371
purple	   	= #581845
teal	    	= #008080
gray		= #505050
foamGreen 	= #93E9BE

[bar/top]
; Size
width  = 100%
height = 20

; Offset
;offset-x = 50%
;offset-y = 50%

; Position
bottom = false

; Radius
radius = 0

; Align modules fixed to middle
fixed-center = true

; Colors
background = ${colors.background}
foreground = ${colors.foreground}

; Underline
line-size  = 2
line-color = ${colors.foreground}

; Border
border-size  = 0
border-color = ${colors.black}

; Padding
padding-left  = 0
padding-right = 0

; Margin of modules
module-margin-left  = 0
module-margin-right = 0

; Font
font-0 =Droid Sans Mono:style=Bold:size=10;3
font-1 = Font Awesome 5 Free Solid:size=10;3
font-2 = Font Awesome 5 Brands:size=10;3

; Modlues
modules-left   =  rofi sep alacritty opera nautilus vscode gimp sep bspwm 
modules-center = date time
modules-right  = wireless-network bluetooth eth sep battery xbacklight pavolume sep lock pmenu

;Make the bar appear below windows
;wm-restack = i3
;override-redirect = true

; Cursor actions
cursor-click  = pointer
cursor-scroll = ns-resize

[module/bspwm]
type = internal/bspwm

; Mouse click
enable-click = true

; Mouse scroll
enable-scroll = false

; Sort
index-sort = true

; Display icons
fuzzy-match = true

; Icons
ws-icon-0       = 1;
ws-icon-1       = 2;
ws-icon-2       = 3;
ws-icon-3       = 4;
ws-icon-4       = 5;
ws-icon-5	= 6;
ws-icon-6	= 7;

; Focused label
label-focused            = %icon%
label-focused-background = ${colors.background}
label-focused-foreground = ${colors.darkRed}
label-focused-padding    = 1

; Unfocused labels
label-unfocused            = %icon%
label-unfocused-foreground = ${colors.rose}
label-unfocused-padding    = 1

; Visible labels
label-visible            = %icon%
label-visible-foreground = ${colors.green}
label-visible-padding    = 1

label-empty = %icon%
label-empty-foreground = ${colors.silverGray}
label-empty-padding = 1

label-occupied = %icon%
label-occupied-foreground = ${colors.foamGreen}
label-occupied-padding = 1


; Urgent labels
label-urgent            = %icon%
label-urgent-foreground = ${colors.green}
label-urgent-padding    = 1
; Separator in between workspaces
; label-separator = |

;[module/updates]
;type = custom/script
;exec = ~/.config/polybar/scripts/arch-updates.sh
;interval = 1000
;label = Updates: %output%
;format-foreground = ${colors.foreground}
;format-background = ${colors.background}
;format-prefix = " "
;format-prefix-foreground = $(colors.foreground)
;label-urgent-padding    = 2

[module/xbacklight]
type = internal/xbacklight
format = <label>
format-prefix = " "
format-prefix-foreground = ${colors.foreground}
;label-foreground = ${colors.green}
format-padding = 1

[module/battery]
;https://github.com/jaagr/polybar/wiki/Module:-battery
type = internal/battery
battery = BAT0
adapter = AC0
full-at = 95

format-charging = <animation-charging> <label-charging>
label-charging =  %percentage%%
lable-charging-foreground = ${colors.green}
format-charging-foreground = ${colors.green}
format-charging-background = ${colors.background}

format-discharging = <ramp-capacity> <label-discharging>
label-discharging =  %percentage%%
label-discharging-foreground = ${colors.green}
format-discharging-foreground = ${colors.green}
format-discharging-background = ${colors.background}

format-full-prefix = " "
format-full-prefix-foreground = ${colors.foreground}
format-full-prefix-padding-left = 1
format-foreground = ${colors.foreground}
format-background = ${colors.background}

ramp-capacity-0 = 
ramp-capacity-1 = 
ramp-capacity-2 = 
ramp-capacity-3 = 
ramp-capacity-4 = 
ramp-capacity-foreground = ${colors.green}

animation-charging-0 = 
animation-charging-1 = 
animation-charging-2 = 
animation-charging-3 = 
animation-charging-4 = 
animation-charging-foreground = ${colors.green}
animation-charging-framerate = 750


;[module/uptime]
;;https://github.com/jaagr/polybar/wiki/User-contributed-modules#uptime
;type = custom/script
;exec = uptime | awk -F, '{sub(".*up ",x,$1);print $1}'
;interval = 100
;label =: %output%

;format-foreground = ${colors.green}
;format-background = ${colors.background}
;format-prefix = ""
;format-prefix-foreground = ${colors.green}
;label-padding    = 1

[module/wireless-network]
type = internal/network
interface = wlp3s0
interval = 3.0
udspeed-minwidth = 0
format-connected = <label-connected>
format-disconnected = <label-disconnected>
label-disconnected = "%{A1:alacritty -e nmtui:}%{A3:nmcli radio wifi on &:}%{A}%{A}"
label-connected = "%{A1:alacritty -e nmtui:}%{A3:nmcli radio wifi off &:} %essid%%{A}%{A}"
label-disconnected-foreground = ${colors.silverGray}
label-connected-foreground = ${colors.foreground}
label-disconnected-padding    = 1

[module/pavolume]
type = custom/script
tail = true
label = %output%
exec = ~/.config/polybar/scripts/pavolume.sh --listen
;click-right = exec pavucontrol
click-left = ~/.config/polybar/scripts/pavolume.sh --togmute
scroll-up = ~/.config/polybar/scripts/pavolume.sh --up
scroll-down = ~/.config/polybar/scripts/pavolume.sh --down
format-foreground = ${colors.foreground}
label-padding    = 1
format-background = ${colors.background}

;[module/temperature]
;type = internal/temperature

; Label
;label            =  %temperature%
;label-background = ${colors.background}
;label-foreground = ${colors.green}
;label-padding    = 1

; Warning label
;label-warn            =  %temperature%
;label-warn-background = ${colors.background}
;label-warn-foreground = ${colors.green}
;label-warn-padding    = 1

;[module/pulseaudio]
;type = internal/pulseaudio

; Volume label
;label-volume            =  %percentage%%
;label-volume-background = ${colors.green}
;label-volume-foreground = ${colors.foreground}
;label-volume-padding    = 1

; Muted label
;label-muted            =  Muted
;label-muted-background = ${colors.green}
;label-muted-foreground = ${colors.foreground}
;label-muted-padding    = 1

;[module/networkspeedup]
;https://github.com/jaagr/polybar/wiki/Module:-network
;type = internal/network
;interface = wlp3s0
;interface = enp4s0f2
;interface = enp0s31f6
;interface = wlo1
;label-connected = "%upspeed:7%"
;format-connected = <label-connected>
;format-connected-prefix = " "
;format-connected-prefix-foreground = ${colors.foreground}
;format-connected-foreground = ${colors.foreground}
;format-connected-background = ${colors.background}

;[module/networkspeeddown]
;https://github.com/jaagr/polybar/wiki/Module:-network
;type = internal/network
;interface = wlp3s0
;interface = enp4s0f2
;interface = enp0s31f6
;interface = wlo1
;label-connected = "%downspeed:7%"
;format-connected = <label-connected>
;format-connected-prefix = "  "
;format-connected-prefix-foreground = ${colors.foreground}
;format-connected-foreground = ${colors.foreground}
;format-connected-background = ${colors.background}

[module/date]
type = internal/date
; Seconds to sleep between updates
interval = 5
date = " %a %b %d, %Y"
format-prefix = " "
format-prefix-foreground = ${colors.foreground}
format-foreground = ${colors.foreground}
format-background = ${colors.background}

[module/time]
type = internal/date

; Update interval
interval = 1.0

; Format
time = %H:%M

; Label
label            =  %time%
label-foreground = ${colors.foreground}
label-background = ${colors.background}
label-padding    = 1

; Bluetooth module
[module/bluetooth]
type = custom/script
exec = ~/.config/polybar/scripts/bluetooth.sh
interval = 2
click-left = blueman-manager &
click-right = ~/.config/polybar/scripts/toggle-bluetooth.sh
format-padding = 1
format-foreground = #ffffff

[module/sep]
type = custom/text
content = |
content-foreground = ${colors.iceColor}
content-background = ${colors.background}
content-padding = 1

[module/lock]
type = custom/text

; Label
content = 
content-background = ${colors.background}
content-foreground = ${colors.foreground}
content-padding    = 1

; Mouse click
click-left = slock

[module/logout]
type = custom/text

; Label
content            = 
content-background = ${colors.background}
content-foreground = ${colors.foreground}
content-padding    = 1

; Mouse click
click-left =  bspc quit

[module/reboot]
type = custom/text

; Label
content            = 
content-background = ${colors.background}
content-foreground = ${colors.foreground}
content-padding    = 1

; Mouse click
click-left = reboot

[module/poweroff]
type = custom/text

; Label
content            = 
content-background = ${colors.background}
content-foreground = ${colors.foreground}
content-padding    = 1

; Mouse click
click-left = poweroff

[module/opera]
type = custom/text

; Label
content            = 
content-background = ${colors.background}
content-foreground = ${colors.foreground}
content-padding    = 1

; Mouse click
click-left = opera &

[module/vscode]
type = custom/text

; Label
content            = 
content-background = ${colors.background}
content-foreground = ${colors.foreground}
content-padding    = 1

; Mouse click
click-left = code &

[module/gimp]
type = custom/text

; Label
content            = 
content-background = ${colors.background}
content-foreground = ${colors.foreground}
content-padding    = 1

; Mouse click
click-left = gimp &

[module/alacritty]
type = custom/text

; Label
content            = 
content-background = ${colors.background}
content-foreground = ${colors.foreground}
content-padding    = 1

; Mouse click
click-left = alacritty & 

[module/nautilus]
type = custom/text

; Label
content            = 
content-background = ${colors.background}
content-foreground = ${colors.foreground}
content-padding    = 1

; Mouse click
click-left = nautilus &

[module/rofi]
type = custom/text

; Label
content            = 
content-background = ${colors.background}
content-foreground = ${colors.foreground}
content-padding    = 1

; Mouse click
click-left = rofi -show drun -show-icons &

[module/eth]
type = internal/network
interface = enp4s0f2
format-connected = <label-connected>
label-connected = 
label-connected-foreground = ${colors.foreground}
label-connected-padding = 1
format-disconnected = 
format-disconnected-foreground = ${colors.silverGray}
format-disconnected-padding = 1

[module/pmenu]
type = custom/menu
format-spacing = 1

label-open = 
label-open-foreground = ${colors.foreground}
label-open-padding = 1
label-close = 
label-close-padding = 1
label-close-foreground = ${colors.silverGray}
label-separator = |
label-separator-foreground = ${colors.iceColor}


menu-0-0 = 
menu-0-0-foreground = ${colors.foamGreen}
menu-0-0-exec = menu-open-1
menu-0-0-padding = 1
menu-0-1 = 
menu-0-1-foreground = ${colors.foamGreen}
menu-0-1-exec = menu-open-2
menu-0-1-padding = 1

menu-1-0 = 
menu-1-0-foreground = ${colors.darkRed}
menu-1-0-exec = menu-open-0
menu-1-0-padding = 1

menu-1-1 = 
menu-1-1-foreground = ${colors.darkRed}
menu-1-1-exec = reboot
menu-1-1-padding = 1

menu-2-0 = 
menu-2-0-foreground = ${colors.darkRed}
menu-2-0-exec = poweroff
menu-2-0-padding = 1
menu-2-1 = 
menu-2-1-foreground = ${colors.darkRed}
menu-2-1-exec = menu-open-0
menu-2-1-padding = 1

[settings]
screenchange-reload     = true
;compositing-background = xor
;compositing-foreground = source
;compositing-border     = over
;pseudo-transparency    = false

